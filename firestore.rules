rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------------
    // Helpers
    // ---------------------------------------------------------------
    function estaAutenticado() {
      return request.auth != null;
    }

    function rolDe(uid) {
      return get(/databases/$(database)/documents/usuarios/$(uid)).data.role;
    }

    function esMaestro() {
      return estaAutenticado() && rolDe(request.auth.uid) == 'master';
    }

    function esComisionista() {
      return estaAutenticado() && rolDe(request.auth.uid) == 'collector';
    }

    // ---------------------------------------------------------------
    // /usuarios
    // ---------------------------------------------------------------
    match /usuarios/{uid} {
      allow get: if estaAutenticado() && (request.auth.uid == uid || esMaestro());
      allow list: if esMaestro();
      allow create: if esMaestro();
      allow update: if esMaestro() ||
        (request.auth.uid == uid && request.resource.data.role == resource.data.role);
      allow delete: if esMaestro();
    }

    // ---------------------------------------------------------------
    // /clientes
    // ---------------------------------------------------------------
    match /clientes/{clienteId} {
      allow get: if esMaestro() ||
        (esComisionista() && resource.data.comisionistaId == request.auth.uid);
      allow list: if esMaestro() || esComisionista();
      allow create: if esComisionista() &&
        request.resource.data.comisionistaId == request.auth.uid;
      allow update: if esMaestro() ||
        (esComisionista() && resource.data.comisionistaId == request.auth.uid);
      allow delete: if esMaestro();
    }

    // ---------------------------------------------------------------
    // /prestamos
    // ---------------------------------------------------------------
    match /prestamos/{prestamoId} {
      allow get: if esMaestro() ||
        (esComisionista() && resource.data.comisionistaId == request.auth.uid);
      allow list: if esMaestro() || esComisionista();
      allow create: if esComisionista() &&
        request.resource.data.comisionistaId == request.auth.uid;
      allow update: if esMaestro() ||
        (esComisionista() && resource.data.comisionistaId == request.auth.uid);
      allow delete: if esMaestro();

      // /prestamos/{prestamoId}/cuotas
      // FIX: la regla ahora lee comisionistaId directamente del documento
      // de la cuota (request.resource.data) en vez de hacer get() al
      // padre. Esto es necesario porque en un batch write el documento
      // padre aun no existe cuando Firestore evalua las reglas de las
      // cuotas hijas, haciendo que el get() devuelva null y bloquee
      // la escritura. Al guardar comisionistaId en cada cuota, la
      // validacion es instantanea y no depende del padre.
      match /cuotas/{cuotaId} {
        allow get: if esMaestro() ||
          (esComisionista() && resource.data.comisionistaId == request.auth.uid);
        allow list: if esMaestro() ||
          (esComisionista() && resource.data.comisionistaId == request.auth.uid);
        allow create: if esComisionista() &&
          request.resource.data.comisionistaId == request.auth.uid;
        allow update: if esComisionista() &&
          resource.data.comisionistaId == request.auth.uid;
        allow delete: if esMaestro();
      }
    }

    // ---------------------------------------------------------------
    // /codigos_yape_registrados - control anti-fraude
    // ---------------------------------------------------------------
    match /codigos_yape_registrados/{codigo} {
      allow get: if esMaestro() || esComisionista();
      allow list: if esMaestro();
      allow create: if esComisionista() &&
        request.resource.data.comisionistaId == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
