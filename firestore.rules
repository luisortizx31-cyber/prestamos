rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------------
    // Helpers
    // ---------------------------------------------------------------
    function estaAutenticado() {
      return request.auth != null;
    }

    function rolDe(uid) {
      return get(/databases/$(database)/documents/usuarios/$(uid)).data.role;
    }

    function esMaestro() {
      return estaAutenticado() && rolDe(request.auth.uid) == 'master';
    }

    // INHABILITAR COMISIONISTA: si el Maestro lo inhabilita (activo:
    // false), este helper debe cortarle el acceso de una, sin importar
    // que su sesion de Firebase Auth siga tecnicamente vigente en el
    // navegador. Por eso va DENTRO de esComisionista() y no solo en la
    // UI (ver ProtectedRoute.jsx, que solo es una conveniencia visual).
    // Igual que en creditoAprobado(), se chequea "in" antes de leer el
    // campo para no romper la evaluacion en comisionistas viejos que
    // todavia no tienen este campo.
    function activoDe(uid) {
      let datos = get(/databases/$(database)/documents/usuarios/$(uid)).data;
      return !('activo' in datos) || datos.activo != false;
    }

    function esComisionista() {
      return estaAutenticado() && rolDe(request.auth.uid) == 'collector' &&
        activoDe(request.auth.uid);
    }

    // SOLICITUDES DE CREDITO: el comisionista no puede registrar ningun
    // cobro mientras el prestamo no este aprobado por el Maestro. Los
    // prestamos sin el campo estadoSolicitud (creados antes de este
    // flujo) se consideran aprobados por compatibilidad - ese dinero ya
    // se habia desembolsado en la vida real.
    //
    // IMPORTANTE: se chequea primero si el campo EXISTE con el
    // operador "in" antes de leer su valor. Acceder directo a un campo
    // que no existe (get(...).data.campo) puede hacer fallar TODA la
    // evaluacion de la regla en vez de devolver null, lo que bloqueaba
    // injustamente los prestamos antiguos sin este campo.
    function creditoAprobado(prestamoId) {
      let datos = get(/databases/$(database)/documents/prestamos/$(prestamoId)).data;
      return !('estadoSolicitud' in datos) ||
        (datos.estadoSolicitud != 'pendiente' && datos.estadoSolicitud != 'rechazado');
    }

    // EDICION DE SOLICITUD: el comisionista puede editar las condiciones
    // de su propio prestamo (y regenerar su cronograma de cuotas) SOLO
    // mientras sigue "pendiente" de aprobacion — en ese estado ninguna
    // cuota pudo haberse cobrado todavia (ver creditoAprobado() arriba),
    // asi que no hay riesgo de pisar pagos reales.
    function prestamoPendiente(prestamoId) {
      let datos = get(/databases/$(database)/documents/prestamos/$(prestamoId)).data;
      return ('estadoSolicitud' in datos) && datos.estadoSolicitud == 'pendiente';
    }

    // ---------------------------------------------------------------
    // Acceso especial para COLLECTION GROUP QUERIES sobre /cuotas
    // (ej. Conciliacion de Caja necesita ver TODAS las cuotas
    // "por_verificar" de TODOS los comisionistas en una sola consulta,
    // y ChecklistDelDia.jsx necesita ver TODAS las cuotas propias del
    // comisionista repartidas en distintos prestamos, en una sola
    // consulta), usando collectionGroup() en el cliente. Firestore
    // exige una regla con wildcard recursivo {path=**} para autorizar
    // este tipo de consulta - la regla anidada normal (mas abajo,
    // dentro de /prestamos/{prestamoId}/cuotas) NO aplica para
    // collectionGroup(), solo para consultas/lecturas directas a la
    // subcoleccion de un prestamo especifico.
    // ---------------------------------------------------------------
    match /{path=**}/cuotas/{cuotaId} {
      allow list: if esMaestro() ||
        (esComisionista() && resource.data.comisionistaId == request.auth.uid);
      allow get: if esMaestro() ||
        (esComisionista() && resource.data.comisionistaId == request.auth.uid);
    }

    // ---------------------------------------------------------------
    // /usuarios
    // ---------------------------------------------------------------
    match /usuarios/{uid} {
      allow get: if estaAutenticado() && (request.auth.uid == uid || esMaestro());
      allow list: if esMaestro();
      allow create: if esMaestro();
      allow update: if esMaestro() ||
        (request.auth.uid == uid && request.resource.data.role == resource.data.role);
      allow delete: if esMaestro();
    }

    // ---------------------------------------------------------------
    // /clientes
    // ---------------------------------------------------------------
    match /clientes/{clienteId} {
      allow get: if esMaestro() ||
        (esComisionista() && resource.data.comisionistaId == request.auth.uid);
      allow list: if esMaestro() || esComisionista();
      // "Mi Cartera": el Maestro tambien puede registrar clientes
      // propios y actuar como su propio comisionista (ver
      // TabMiCartera.jsx), sin necesidad de pasar por aprobacion.
      allow create: if (esComisionista() || esMaestro()) &&
        request.resource.data.comisionistaId == request.auth.uid;
      allow update: if esMaestro() ||
        (esComisionista() && resource.data.comisionistaId == request.auth.uid);
      allow delete: if esMaestro();
    }

    // ---------------------------------------------------------------
    // /prestamos
    // ---------------------------------------------------------------
    match /prestamos/{prestamoId} {
      allow get: if esMaestro() ||
        (esComisionista() && resource.data.comisionistaId == request.auth.uid);
      allow list: if esMaestro() || esComisionista();
      // "Mi Cartera": el Maestro tambien puede registrar prestamos
      // propios (autoAprobados, ver crearPrestamoConCronograma).
      allow create: if (esComisionista() || esMaestro()) &&
        request.resource.data.comisionistaId == request.auth.uid;
      // El comisionista solo puede editar SU prestamo mientras sigue
      // "pendiente" — una vez aprobado o rechazado por el Maestro, las
      // condiciones ya no se pueden tocar (ver RegistroPrestamo.jsx,
      // modo edicion, y BotonEditarPrestamo.jsx que oculta el boton
      // fuera de ese estado).
      allow update: if esMaestro() ||
        (esComisionista() &&
         resource.data.comisionistaId == request.auth.uid &&
         'estadoSolicitud' in resource.data &&
         resource.data.estadoSolicitud == 'pendiente');
      allow delete: if esMaestro();

      // /prestamos/{prestamoId}/cuotas
      //
      // CONCILIACION DE CAJA EN DOS PASOS - regla critica:
      // El comisionista puede CREAR y actualizar sus propias cuotas,
      // pero JAMAS puede dejar una cuota en estado "pagado" el mismo.
      // Solo el Maestro puede escribir estado == "pagado" (lo hace
      // desde conciliacionService.js al aprobar). Esto se aplica aqui,
      // a nivel de servidor, para que ni siquiera alguien manipulando
      // el codigo del navegador pueda saltarse la aprobacion.
      match /cuotas/{cuotaId} {
        allow get: if esMaestro() ||
          (esComisionista() && resource.data.comisionistaId == request.auth.uid);

        // separadas en dos reglas (en vez de una sola con ||): el
        // Maestro necesita poder listar TODAS las cuotas de TODOS los
        // comisionistas (ej. conciliacion de caja), sin filtrar por
        // comisionistaId en la consulta. Si esta regla estuviera
        // combinada con la del comisionista en un solo "||", Firestore
        // exige que la consulta tenga un where() sobre comisionistaId
        // para CUALQUIERA de las dos ramas, aunque la rama del Maestro
        // no dependa de ese campo. Separarlas en dos "allow list"
        // independientes evita ese problema: la del Maestro no
        // referencia ningun campo del documento, asi que no necesita
        // filtro alguno.
        allow list: if esMaestro();
        allow list: if esComisionista() && resource.data.comisionistaId == request.auth.uid;

        allow create: if (esComisionista() || esMaestro()) &&
          request.resource.data.comisionistaId == request.auth.uid;
        // El "|| prestamoPendiente(...)" es lo que permite regenerar el
        // cronograma al editar una solicitud pendiente (RegistroPrestamo.jsx
        // borra y vuelve a crear las cuotas). En ese estado nunca se
        // puede escribir estado == 'pagado' (ya lo bloquea la condicion
        // de arriba), asi que no hay riesgo de aprobar cobros sin pasar
        // por el Maestro.
        allow update: if esMaestro() ||
          (esComisionista() &&
           resource.data.comisionistaId == request.auth.uid &&
           request.resource.data.estado != 'pagado' &&
           (creditoAprobado(prestamoId) || prestamoPendiente(prestamoId)));
        allow delete: if esMaestro() ||
          (esComisionista() &&
           resource.data.comisionistaId == request.auth.uid &&
           prestamoPendiente(prestamoId));
      }
    }

    // ---------------------------------------------------------------
    // /codigos_yape_registrados - control anti-fraude
    // ---------------------------------------------------------------
    match /codigos_yape_registrados/{codigo} {
      allow get: if esMaestro() || esComisionista();
      allow list: if esMaestro();
      // El Maestro puede cobrar cuotas de clientes que no son suyos
      // (ver ConfirmarClaveMaestro.jsx) — el cobro se registra a nombre
      // del comisionista DUEÑO del cliente, no del Maestro, asi que aqui
      // el comisionistaId del documento no necesariamente es
      // request.auth.uid cuando quien escribe es el Maestro.
      allow create: if (esComisionista() && request.resource.data.comisionistaId == request.auth.uid) ||
        esMaestro();
      allow update: if false;
      // Solo el Maestro puede borrar (libera el codigo al rechazar una
      // cuota desde conciliacionService.rechazarCuota). El comisionista
      // nunca puede borrar registros anti-fraude.
      allow delete: if esMaestro();
    }

    // ---------------------------------------------------------------
    // /recalendarizaciones - historial de pagos "solo interes"
    // (ver recalendarizacionService.js). Se aplican de inmediato, sin
    // pasar por Conciliacion de Caja, asi que no requieren un helper
    // especial como creditoAprobado()/prestamoPendiente().
    // ---------------------------------------------------------------
    match /recalendarizaciones/{id} {
      allow get: if esMaestro() ||
        (esComisionista() && resource.data.comisionistaId == request.auth.uid);
      allow list: if esMaestro() || esComisionista();
      // Igual que codigos_yape_registrados: el Maestro puede registrar
      // esto a nombre del comisionista dueño del cliente, no solo del
      // suyo propio (ver ConfirmarClaveMaestro.jsx).
      allow create: if (esComisionista() && request.resource.data.comisionistaId == request.auth.uid) ||
        esMaestro();
      allow update: if false;
      allow delete: if esMaestro();
    }
  }
}
